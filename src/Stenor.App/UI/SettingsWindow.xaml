<Window x:Class="Stenor.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stenor Settings"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI">
    <StackPanel Margin="28,10,28,24">

        <TextBlock Text="Gemini API key" Style="{StaticResource FieldLabel}" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <PasswordBox x:Name="ApiKeyBox" Style="{StaticResource DarkPasswordBox}"
                         PasswordChanged="OnApiKeyChanged" />
            <TextBox x:Name="ApiKeyVisibleBox" Style="{StaticResource DarkTextBox}"
                     Visibility="Collapsed" TextChanged="OnApiKeyVisibleChanged" />
            <Button x:Name="ToggleKeyVisibilityButton" Grid.Column="1" Style="{StaticResource DarkButton}"
                    Content="Show" Width="64" Margin="8,0,0,0" Click="OnToggleKeyVisibility" />
        </Grid>
        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" FontSize="12">
                <Hyperlink NavigateUri="https://aistudio.google.com/apikey"
                           RequestNavigate="OnNavigate"
                           Foreground="{StaticResource AccentBrush}">Get a key → aistudio.google.com/apikey</Hyperlink>
            </TextBlock>
            <Button x:Name="TestKeyButton" Grid.Column="1" Style="{StaticResource DarkButton}"
                    Content="Test key" Click="OnTestKey" />
        </Grid>
        <TextBlock x:Name="TestResultText" FontSize="12" Margin="0,6,0,0"
                   Visibility="Collapsed" TextWrapping="Wrap" />

        <TextBlock Text="Spoken languages" Style="{StaticResource FieldLabel}" />
        <ToggleButton x:Name="LanguagesToggle" Style="{StaticResource DarkDropdownToggle}" Height="36"
                      PreviewMouseLeftButtonDown="OnLanguagesToggleMouseDown">
            <TextBlock x:Name="LanguagesSummary" TextTrimming="CharacterEllipsis" />
        </ToggleButton>
        <Popup x:Name="LanguagesPopup" PlacementTarget="{Binding ElementName=LanguagesToggle}"
               Placement="Bottom" AllowsTransparency="True" StaysOpen="False"
               IsOpen="{Binding IsChecked, ElementName=LanguagesToggle, Mode=TwoWay}"
               Opened="OnLanguagesPopupOpened" Closed="OnLanguagesPopupClosed">
            <Border Background="{StaticResource ControlBrush}" BorderBrush="{StaticResource EdgeBrush}"
                    BorderThickness="1" CornerRadius="8" Margin="0,4,0,0"
                    MinWidth="{Binding ActualWidth, ElementName=LanguagesToggle}">
                <DockPanel>
                    <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource EdgeBrush}"
                            BorderThickness="0,1,0,0" Padding="14,7">
                        <CheckBox x:Name="AutoDetectCheck" Style="{StaticResource DarkCheckBox}"
                                  Content="Auto-detect" Padding="6,0,0,0"
                                  Checked="OnAutoDetectChecked" Unchecked="OnAutoDetectUnchecked" />
                    </Border>
                    <ScrollViewer x:Name="LanguagesScroll" VerticalScrollBarVisibility="Auto" MaxHeight="240">
                        <StackPanel x:Name="LanguagesPanel" Margin="0,4" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Popup>
        <TextBlock Text="The languages you dictate in — helps Gemini recognize your speech more accurately. Leave on Auto-detect if unsure."
                   Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="2,5,0,0" TextWrapping="Wrap" />

        <TextBlock Text="Hotkey" Style="{StaticResource FieldLabel}" />
        <Button x:Name="HotkeyButton" Style="{StaticResource DarkButton}"
                HorizontalContentAlignment="Left" Click="OnHotkeyButtonClick" />
        <TextBlock Text="Click, then press the key or combo you want (Esc cancels)."
                   Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="2,5,0,0" />

        <TextBlock Text="Activation mode" Style="{StaticResource FieldLabel}" />
        <RadioButton x:Name="HoldRadio" Style="{StaticResource DarkRadio}" GroupName="Mode"
                     Content="Hold — record while the hotkey is held (push-to-talk)" />
        <RadioButton x:Name="ToggleRadio" Style="{StaticResource DarkRadio}" GroupName="Mode"
                     Content="Toggle — press to start, press again to stop" />

        <CheckBox x:Name="StartupCheck" Style="{StaticResource DarkCheckBox}" Margin="0,14,0,0"
                  Content="Launch Stenor at Windows startup" />

        <CheckBox x:Name="LiveTypingCheck" Style="{StaticResource DarkCheckBox}" Margin="0,10,0,0"
                  Content="Live typing (experimental) — type while you speak" />
        <TextBlock Text="Streams audio to Gemini Live and types each sentence as you pause. Output is rawer than the default mode and is always typed character by character (the clipboard is not used)."
                   Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="24,4,0,0" TextWrapping="Wrap" />

        <TextBlock x:Name="ValidationText" Foreground="{StaticResource DangerBrush}" FontSize="12"
                   Margin="0,14,0,0" Visibility="Collapsed" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button Style="{StaticResource AccentButton}" Content="Save"
                    Width="92" Click="OnSave" />
            <Button Style="{StaticResource DarkButton}" Content="Cancel"
                    Width="92" Margin="10,0,0,0" Click="OnCancel" />
        </StackPanel>
    </StackPanel>
</Window>
